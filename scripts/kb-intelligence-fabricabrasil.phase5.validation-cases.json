{
  "description": "Validation cases for KB Intelligence Phase 5 semantic relation increments using the FabricaBrasil parallel KB.",
  "cases": [
    {
      "id": "phase5-case-1-transaction-attcustomtype-resolves-sdt-context",
      "source": "Transaction:AbateOrdem",
      "target": "SDT:Context",
      "expected_rule": "attcustomtype_resolved_object",
      "should_exist": true,
      "expectation": "ATTCUSTOMTYPE sdt:Context in Transaction must resolve to SDT:Context"
    },
    {
      "id": "phase5-case-2-procedure-attcustomtype-resolves-sdt-context",
      "source": "Procedure:ExportWWOperacaoAjustada",
      "target": "SDT:Context",
      "expected_rule": "attcustomtype_resolved_object",
      "should_exist": true,
      "expectation": "ATTCUSTOMTYPE sdt:Context in Procedure must resolve to SDT:Context"
    },
    {
      "id": "phase5-case-3-literal-customtype-is-preserved",
      "source": "Transaction:AbateOrdem",
      "target": "CustomType:sdt:Context",
      "expected_rule": "attcustomtype_property",
      "should_exist": true,
      "expectation": "Resolved ATTCUSTOMTYPE relation must not replace the literal CustomType relation"
    },
    {
      "id": "phase5-case-4-builtin-bas-boolean-does-not-resolve-domain",
      "source": "Transaction:AbateOrdem",
      "target": "Domain:Boolean",
      "expected_rule": "attcustomtype_resolved_object",
      "should_exist": false,
      "expectation": "Built-in bas:Boolean must not be forced to Domain:Boolean"
    },
    {
      "id": "phase5-case-5-unknown-sdt-does-not-resolve",
      "source": "Transaction:AbateOrdem",
      "target": "SDT:TipoInexistenteParaNaoIndexar",
      "expected_rule": "attcustomtype_resolved_object",
      "should_exist": false,
      "expectation": "Unknown CustomType target must not create a resolved relation"
    },
    {
      "id": "phase5-case-6-attribute-idbasedon-resolves-domain-data",
      "source": "Attribute:AbateOrdemData",
      "target": "Domain:Data",
      "expected_rule": "attribute_idbasedon_domain",
      "should_exist": true,
      "expectation": "Attribute idBasedOn Domain:Data must resolve to Domain:Data when the Domain object exists"
    },
    {
      "id": "phase5-case-7-attribute-idbasedon-resolves-domain-cancelado",
      "source": "Attribute:AbateOrdemCancelado",
      "target": "Domain:Cancelado",
      "expected_rule": "attribute_idbasedon_domain",
      "should_exist": true,
      "expectation": "Attribute idBasedOn Domain:Cancelado must resolve to Domain:Cancelado when the Domain object exists"
    },
    {
      "id": "phase5-case-8-external-gx-domain-does-not-resolve",
      "source": "Attribute:EmpresaGeolocalizacao",
      "target": "Domain:Geolocation, GeneXus",
      "expected_rule": "attribute_idbasedon_domain",
      "should_exist": false,
      "expectation": "External GeneXus domains must not create resolved Domain relations when absent from the local inventory"
    },
    {
      "id": "phase5-case-9-attribute-without-idbasedon-does-not-resolve-domain",
      "source": "Attribute:AbateOrdemAnimaisCanceladoContagem",
      "target": "Domain:AnimaisContagem",
      "expected_rule": "attribute_idbasedon_domain",
      "should_exist": false,
      "expectation": "Attribute without idBasedOn must not create an Attribute to Domain relation"
    },
    {
      "id": "phase5-case-10-transaction-level-key-attribute",
      "source": "Transaction:AbateOrdem",
      "target": "Attribute:AbateOrdemEmpresaId",
      "expected_rule": "transaction_level_attribute",
      "should_exist": true,
      "expectation": "Transaction Level Attribute element for a key attribute must create a Transaction to Attribute relation"
    },
    {
      "id": "phase5-case-11-transaction-level-non-key-attribute",
      "source": "Transaction:AbateOrdem",
      "target": "Attribute:AbateOrdemData",
      "expected_rule": "transaction_level_attribute",
      "should_exist": true,
      "expectation": "Transaction Level Attribute element for a non-key attribute must create a Transaction to Attribute relation"
    },
    {
      "id": "phase5-case-12-transaction-does-not-link-unlisted-attribute",
      "source": "Transaction:AbateOrdem",
      "target": "Attribute:VolumeMovimentoId",
      "expected_rule": "transaction_level_attribute",
      "should_exist": false,
      "expectation": "Existing Attribute absent from the Transaction Level must not create a Transaction to Attribute relation"
    },
    {
      "id": "phase5-case-13-transaction-does-not-link-missing-attribute",
      "source": "Transaction:AbateOrdem",
      "target": "Attribute:ObjetoInexistenteParaNaoIndexar",
      "expected_rule": "transaction_level_attribute",
      "should_exist": false,
      "expectation": "Transaction Level extraction must not create a relation to an unresolved Attribute"
    },
    {
      "id": "phase5-case-14-table-key-attribute-abate-ordem-empresa",
      "source": "Table:AbateOrdem",
      "target": "Attribute:AbateOrdemEmpresaId",
      "expected_rule": "table_key_attribute",
      "should_exist": true,
      "expectation": "Table Key Item element must create a Table to Attribute relation for a primary key attribute"
    },
    {
      "id": "phase5-case-15-table-key-attribute-abate-ordem-id",
      "source": "Table:AbateOrdem",
      "target": "Attribute:AbateOrdemId",
      "expected_rule": "table_key_attribute",
      "should_exist": true,
      "expectation": "Second Table Key Item element must create a Table to Attribute relation for a composite primary key"
    },
    {
      "id": "phase5-case-16-table-index-member-does-not-create-key-relation",
      "source": "Table:AbateOrdem",
      "target": "Attribute:AbateOrdemData",
      "expected_rule": "table_key_attribute",
      "should_exist": false,
      "expectation": "Index member not declared inside Table Key must not create a table_key_attribute relation"
    },
    {
      "id": "phase5-case-17-table-does-not-link-missing-key-attribute",
      "source": "Table:AbateOrdem",
      "target": "Attribute:ObjetoInexistenteParaNaoIndexar",
      "expected_rule": "table_key_attribute",
      "should_exist": false,
      "expectation": "Table Key extraction must not create a relation to an unresolved Attribute"
    },
    {
      "id": "phase5-case-18-transaction-level-type-resolves-table-abate-ordem",
      "source": "Transaction:AbateOrdem",
      "target": "Table:AbateOrdem",
      "expected_rule": "transaction_level_table",
      "should_exist": true,
      "expectation": "Transaction Level Type must create a Transaction to Table relation when the Table object exists"
    },
    {
      "id": "phase5-case-19-transaction-level-type-resolves-table-animal",
      "source": "Transaction:Animal",
      "target": "Table:Animal",
      "expected_rule": "transaction_level_table",
      "should_exist": true,
      "expectation": "Transaction Level Type extraction must work across different Transaction objects"
    },
    {
      "id": "phase5-case-20-transaction-level-type-missing-table-does-not-resolve",
      "source": "Transaction:AnimalParaAbate",
      "target": "Table:AnimalParaAbate",
      "expected_rule": "transaction_level_table",
      "should_exist": false,
      "expectation": "Transaction Level Type must not create a relation when the Table object is absent from the local inventory"
    },
    {
      "id": "phase5-case-21-transaction-does-not-link-unlisted-table",
      "source": "Transaction:AbateOrdem",
      "target": "Table:Animal",
      "expected_rule": "transaction_level_table",
      "should_exist": false,
      "expectation": "Existing Table not declared as a Level Type in the Transaction must not create a relation"
    },
    {
      "id": "phase5-case-22-table-index-member-attribute-abate-ordem-data",
      "source": "Table:AbateOrdem",
      "target": "Attribute:AbateOrdemData",
      "expected_rule": "table_index_member_attribute",
      "should_exist": true,
      "expectation": "Table Index Member element must create a Table to Attribute relation for indexed attributes"
    },
    {
      "id": "phase5-case-23-table-index-member-attribute-abate-ordem-lote",
      "source": "Table:AbateOrdem",
      "target": "Attribute:AbateOrdemLoteDoDia",
      "expected_rule": "table_index_member_attribute",
      "should_exist": true,
      "expectation": "Table Index Member extraction must cover user-defined composite index members"
    },
    {
      "id": "phase5-case-24-table-key-member-is-also-index-member",
      "source": "Table:AbateOrdem",
      "target": "Attribute:AbateOrdemId",
      "expected_rule": "table_index_member_attribute",
      "should_exist": true,
      "expectation": "Primary key attributes may also appear as index members under the separate index member rule"
    },
    {
      "id": "phase5-case-25-table-does-not-link-unlisted-index-member",
      "source": "Table:AbateOrdem",
      "target": "Attribute:VolumeMovimentoId",
      "expected_rule": "table_index_member_attribute",
      "should_exist": false,
      "expectation": "Existing Attribute absent from the Table indexes must not create a table_index_member_attribute relation"
    },
    {
      "id": "phase5-case-26-sdt-item-attcustomtype-resolves-sdt-country-continent",
      "source": "SDT:CountryInfoServicetCountryCodeAndNameGroupedByContinent",
      "target": "SDT:CountryInfoServicetContinent",
      "expected_rule": "sdt_item_attcustomtype_resolved_sdt",
      "should_exist": true,
      "expectation": "SDT Item ATTCUSTOMTYPE with sdt: prefix must create an SDT to SDT relation when the target exists"
    },
    {
      "id": "phase5-case-27-sdt-item-attcustomtype-resolves-sdt-cte",
      "source": "SDT:CTe_cteProc",
      "target": "SDT:CTe_TCTe",
      "expected_rule": "sdt_item_attcustomtype_resolved_sdt",
      "should_exist": true,
      "expectation": "SDT Item ATTCUSTOMTYPE extraction must work across different SDT families"
    },
    {
      "id": "phase5-case-28-sdt-bas-type-does-not-resolve-sdt",
      "source": "SDT:Context",
      "target": "SDT:Context",
      "expected_rule": "sdt_item_attcustomtype_resolved_sdt",
      "should_exist": false,
      "expectation": "SDT Item ATTCUSTOMTYPE with bas: prefix must not create an SDT to SDT relation"
    },
    {
      "id": "phase5-case-29-sdt-does-not-link-unlisted-sdt",
      "source": "SDT:CTe_cteProc",
      "target": "SDT:Context",
      "expected_rule": "sdt_item_attcustomtype_resolved_sdt",
      "should_exist": false,
      "expectation": "Existing SDT not declared as an SDT Item ATTCUSTOMTYPE target must not create a relation"
    },
    {
      "id": "phase5-case-30-procedure-for-each-explicit-table-animal",
      "source": "Procedure:procAnimaisContagemDeUmPeriodo",
      "target": "Table:Animal",
      "expected_rule": "source_for_each_explicit_table",
      "should_exist": true,
      "expectation": "Procedure Source with explicit for each Animal must create a Procedure to Table relation when Table:Animal exists"
    },
    {
      "id": "phase5-case-31-webpanel-for-each-explicit-table-volume",
      "source": "WebPanel:wcVolumeMovimentosComReferenciaAoRomaneio",
      "target": "Table:VolumeMovimento",
      "expected_rule": "source_for_each_explicit_table",
      "should_exist": true,
      "expectation": "WebPanel Source with explicit for each VolumeMovimento must create a WebPanel to Table relation when Table:VolumeMovimento exists"
    },
    {
      "id": "phase5-case-32-for-each-transaction-without-local-table-does-not-resolve",
      "source": "Procedure:procImportaPedidosDaCarga",
      "target": "Table:RetornoPedido",
      "expected_rule": "source_for_each_explicit_table",
      "should_exist": false,
      "expectation": "Explicit for each RetornoPedido must not create a Table relation when Table:RetornoPedido is absent from the local inventory"
    },
    {
      "id": "phase5-case-33-qualified-for-each-target-stays-out-of-scope",
      "source": "Procedure:procAnimalValorPelaCompra",
      "target": "Table:CompraGadoItens",
      "expected_rule": "source_for_each_explicit_table",
      "should_exist": false,
      "expectation": "Qualified targets such as for each CompraGadoItens.Faixas must stay out of this explicit table increment"
    },
    {
      "id": "phase5-case-34-qualified-for-each-prefix-resolves-table",
      "source": "Procedure:procAnimalValorPelaCompra",
      "target": "Table:CompraGadoItens",
      "expected_rule": "source_for_each_qualified_table_prefix",
      "should_exist": true,
      "expectation": "Qualified Source target for each CompraGadoItens.Faixas must create a relation to the table prefix when Table:CompraGadoItens exists"
    },
    {
      "id": "phase5-case-35-qualified-for-each-prefix-resolves-second-table",
      "source": "Procedure:procCondicaoPagamentoPrazoMedio",
      "target": "Table:CondicaoPagamento",
      "expected_rule": "source_for_each_qualified_table_prefix",
      "should_exist": true,
      "expectation": "Qualified Source target for each CondicaoPagamento.Parcelas must create a relation to the table prefix when Table:CondicaoPagamento exists"
    },
    {
      "id": "phase5-case-36-qualified-for-each-member-is-not-table-target",
      "source": "Procedure:procAnimalValorPelaCompra",
      "target": "Table:Faixas",
      "expected_rule": "source_for_each_qualified_table_prefix",
      "should_exist": false,
      "expectation": "Qualified Source target must not create a Table relation to the member name after the dot"
    },
    {
      "id": "phase5-case-37-procedure-bc-load-resolves-transaction",
      "source": "Procedure:procAjustaCompraGadoIdDeAnimais",
      "target": "Transaction:Animal",
      "expected_rule": "source_bc_load_transaction",
      "should_exist": true,
      "expectation": "Procedure Source &animal.Load(...) must create a relation to Transaction:Animal when variable ATTCUSTOMTYPE is bc:Animal"
    },
    {
      "id": "phase5-case-38-webpanel-bc-load-resolves-transaction",
      "source": "WebPanel:WCAbateOrdemAnimal",
      "target": "Transaction:AbateOrdem",
      "expected_rule": "source_bc_load_transaction",
      "should_exist": true,
      "expectation": "WebPanel Source &AbateOrdem.Load(...) must create a relation to Transaction:AbateOrdem when variable ATTCUSTOMTYPE is bc:AbateOrdem"
    },
    {
      "id": "phase5-case-39-bc-load-resolves-transaction-without-table",
      "source": "Procedure:procCargaMudaDataDePedidos",
      "target": "Transaction:RetornoPedido",
      "expected_rule": "source_bc_load_transaction",
      "should_exist": true,
      "expectation": "BC Load must resolve to Transaction when the BC Transaction exists even if no local Table relation exists"
    },
    {
      "id": "phase5-case-40-bc-load-does-not-infer-gam-external-type",
      "source": "Procedure:GAM_CheckUserActivationMethod",
      "target": "Transaction:User",
      "expected_rule": "source_bc_load_transaction",
      "should_exist": false,
      "expectation": "Load receiver without resolvable local bc: Transaction variable type must not create a relation by receiver name"
    },
    {
      "id": "phase5-case-41-procedure-bc-save-resolves-transaction",
      "source": "Procedure:procAjustaCompraGadoIdDeAnimais",
      "target": "Transaction:Animal",
      "expected_rule": "source_bc_save_transaction",
      "should_exist": true,
      "expectation": "Procedure Source &animal.Save() must create a relation to Transaction:Animal when variable ATTCUSTOMTYPE is bc:Animal"
    },
    {
      "id": "phase5-case-42-webpanel-bc-save-resolves-transaction",
      "source": "WebPanel:wpEmbarqueSaida",
      "target": "Transaction:VendaPedido",
      "expected_rule": "source_bc_save_transaction",
      "should_exist": true,
      "expectation": "WebPanel Source &VendaPedido.Save() must create a relation to Transaction:VendaPedido when variable ATTCUSTOMTYPE is bc:VendaPedido"
    },
    {
      "id": "phase5-case-43-bc-save-does-not-infer-external-document",
      "source": "Procedure:ExportWWOperacaoAjustada",
      "target": "Transaction:ExcelDocument",
      "expected_rule": "source_bc_save_transaction",
      "should_exist": false,
      "expectation": "Save receiver without resolvable local bc: Transaction variable type must not create a relation by receiver name"
    }
  ]
}
