{
  "description": "Validation cases for KB Intelligence Phase 5 semantic relation increments using the FabricaBrasil parallel KB.",
  "cases": [
    {
      "id": "phase5-case-1-transaction-attcustomtype-resolves-sdt-context",
      "source": "Transaction:AbateOrdem",
      "target": "SDT:Context",
      "expected_rule": "attcustomtype_resolved_object",
      "should_exist": true,
      "expectation": "ATTCUSTOMTYPE sdt:Context in Transaction must resolve to SDT:Context"
    },
    {
      "id": "phase5-case-2-procedure-attcustomtype-resolves-sdt-context",
      "source": "Procedure:ExportWWOperacaoAjustada",
      "target": "SDT:Context",
      "expected_rule": "attcustomtype_resolved_object",
      "should_exist": true,
      "expectation": "ATTCUSTOMTYPE sdt:Context in Procedure must resolve to SDT:Context"
    },
    {
      "id": "phase5-case-3-literal-customtype-is-preserved",
      "source": "Transaction:AbateOrdem",
      "target": "CustomType:sdt:Context",
      "expected_rule": "attcustomtype_property",
      "should_exist": true,
      "expectation": "Resolved ATTCUSTOMTYPE relation must not replace the literal CustomType relation"
    },
    {
      "id": "phase5-case-4-builtin-bas-boolean-does-not-resolve-domain",
      "source": "Transaction:AbateOrdem",
      "target": "Domain:Boolean",
      "expected_rule": "attcustomtype_resolved_object",
      "should_exist": false,
      "expectation": "Built-in bas:Boolean must not be forced to Domain:Boolean"
    },
    {
      "id": "phase5-case-5-unknown-sdt-does-not-resolve",
      "source": "Transaction:AbateOrdem",
      "target": "SDT:TipoInexistenteParaNaoIndexar",
      "expected_rule": "attcustomtype_resolved_object",
      "should_exist": false,
      "expectation": "Unknown CustomType target must not create a resolved relation"
    },
    {
      "id": "phase5-case-6-attribute-idbasedon-resolves-domain-data",
      "source": "Attribute:AbateOrdemData",
      "target": "Domain:Data",
      "expected_rule": "attribute_idbasedon_domain",
      "should_exist": true,
      "expectation": "Attribute idBasedOn Domain:Data must resolve to Domain:Data when the Domain object exists"
    },
    {
      "id": "phase5-case-7-attribute-idbasedon-resolves-domain-cancelado",
      "source": "Attribute:AbateOrdemCancelado",
      "target": "Domain:Cancelado",
      "expected_rule": "attribute_idbasedon_domain",
      "should_exist": true,
      "expectation": "Attribute idBasedOn Domain:Cancelado must resolve to Domain:Cancelado when the Domain object exists"
    },
    {
      "id": "phase5-case-8-external-gx-domain-does-not-resolve",
      "source": "Attribute:EmpresaGeolocalizacao",
      "target": "Domain:Geolocation, GeneXus",
      "expected_rule": "attribute_idbasedon_domain",
      "should_exist": false,
      "expectation": "External GeneXus domains must not create resolved Domain relations when absent from the local inventory"
    },
    {
      "id": "phase5-case-9-attribute-without-idbasedon-does-not-resolve-domain",
      "source": "Attribute:AbateOrdemAnimaisCanceladoContagem",
      "target": "Domain:AnimaisContagem",
      "expected_rule": "attribute_idbasedon_domain",
      "should_exist": false,
      "expectation": "Attribute without idBasedOn must not create an Attribute to Domain relation"
    },
    {
      "id": "phase5-case-10-transaction-level-key-attribute",
      "source": "Transaction:AbateOrdem",
      "target": "Attribute:AbateOrdemEmpresaId",
      "expected_rule": "transaction_level_attribute",
      "should_exist": true,
      "expectation": "Transaction Level Attribute element for a key attribute must create a Transaction to Attribute relation"
    },
    {
      "id": "phase5-case-11-transaction-level-non-key-attribute",
      "source": "Transaction:AbateOrdem",
      "target": "Attribute:AbateOrdemData",
      "expected_rule": "transaction_level_attribute",
      "should_exist": true,
      "expectation": "Transaction Level Attribute element for a non-key attribute must create a Transaction to Attribute relation"
    },
    {
      "id": "phase5-case-12-transaction-does-not-link-unlisted-attribute",
      "source": "Transaction:AbateOrdem",
      "target": "Attribute:VolumeMovimentoId",
      "expected_rule": "transaction_level_attribute",
      "should_exist": false,
      "expectation": "Existing Attribute absent from the Transaction Level must not create a Transaction to Attribute relation"
    },
    {
      "id": "phase5-case-13-transaction-does-not-link-missing-attribute",
      "source": "Transaction:AbateOrdem",
      "target": "Attribute:ObjetoInexistenteParaNaoIndexar",
      "expected_rule": "transaction_level_attribute",
      "should_exist": false,
      "expectation": "Transaction Level extraction must not create a relation to an unresolved Attribute"
    },
    {
      "id": "phase5-case-14-table-key-attribute-abate-ordem-empresa",
      "source": "Table:AbateOrdem",
      "target": "Attribute:AbateOrdemEmpresaId",
      "expected_rule": "table_key_attribute",
      "should_exist": true,
      "expectation": "Table Key Item element must create a Table to Attribute relation for a primary key attribute"
    },
    {
      "id": "phase5-case-15-table-key-attribute-abate-ordem-id",
      "source": "Table:AbateOrdem",
      "target": "Attribute:AbateOrdemId",
      "expected_rule": "table_key_attribute",
      "should_exist": true,
      "expectation": "Second Table Key Item element must create a Table to Attribute relation for a composite primary key"
    },
    {
      "id": "phase5-case-16-table-index-member-does-not-create-key-relation",
      "source": "Table:AbateOrdem",
      "target": "Attribute:AbateOrdemData",
      "expected_rule": "table_key_attribute",
      "should_exist": false,
      "expectation": "Index member not declared inside Table Key must not create a table_key_attribute relation"
    },
    {
      "id": "phase5-case-17-table-does-not-link-missing-key-attribute",
      "source": "Table:AbateOrdem",
      "target": "Attribute:ObjetoInexistenteParaNaoIndexar",
      "expected_rule": "table_key_attribute",
      "should_exist": false,
      "expectation": "Table Key extraction must not create a relation to an unresolved Attribute"
    },
    {
      "id": "phase5-case-18-transaction-level-type-resolves-table-abate-ordem",
      "source": "Transaction:AbateOrdem",
      "target": "Table:AbateOrdem",
      "expected_rule": "transaction_level_table",
      "should_exist": true,
      "expectation": "Transaction Level Type must create a Transaction to Table relation when the Table object exists"
    },
    {
      "id": "phase5-case-19-transaction-level-type-resolves-table-animal",
      "source": "Transaction:Animal",
      "target": "Table:Animal",
      "expected_rule": "transaction_level_table",
      "should_exist": true,
      "expectation": "Transaction Level Type extraction must work across different Transaction objects"
    },
    {
      "id": "phase5-case-20-transaction-level-type-missing-table-does-not-resolve",
      "source": "Transaction:AnimalParaAbate",
      "target": "Table:AnimalParaAbate",
      "expected_rule": "transaction_level_table",
      "should_exist": false,
      "expectation": "Transaction Level Type must not create a relation when the Table object is absent from the local inventory"
    },
    {
      "id": "phase5-case-21-transaction-does-not-link-unlisted-table",
      "source": "Transaction:AbateOrdem",
      "target": "Table:Animal",
      "expected_rule": "transaction_level_table",
      "should_exist": false,
      "expectation": "Existing Table not declared as a Level Type in the Transaction must not create a relation"
    }
  ]
}
