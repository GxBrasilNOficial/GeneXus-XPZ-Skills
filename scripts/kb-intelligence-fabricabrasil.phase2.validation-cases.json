{
  "description": "Validation cases for KB Intelligence Phase 2 using DataProvider as the first controlled expansion in the FabricaBrasil parallel KB.",
  "cases": [
    {
      "id": "phase2-case-1-dataprovider-procedure-direct-left",
      "source": "DataProvider:dpCargaPedidos",
      "target": "Procedure:procESQUERDA",
      "expected_rule": "procedure_direct_call",
      "should_exist": true,
      "expectation": "DataProvider effective Source direct procedure call must create a direct relation"
    },
    {
      "id": "phase2-case-2-dataprovider-procedure-direct-right",
      "source": "DataProvider:dpCargaPedidos",
      "target": "Procedure:procDIREITA",
      "expected_rule": "procedure_direct_call",
      "should_exist": true,
      "expectation": "Second direct procedure call in the same DataProvider must create a direct relation"
    },
    {
      "id": "phase2-case-3-dataprovider-procedure-direct-recent-links",
      "source": "DataProvider:dpGamMenuSidebarItems",
      "target": "Procedure:procRecentLinksLoad",
      "expected_rule": "procedure_direct_call",
      "should_exist": true,
      "expectation": "DataProvider assignment from direct procedure call must create a direct relation"
    },
    {
      "id": "phase2-case-4-dataprovider-procedure-direct-where",
      "source": "DataProvider:dpSdtTributacaoDadosBasicosSelecaoConformeParametros",
      "target": "Procedure:procTributacaoTemTipoRomaneio",
      "expected_rule": "procedure_direct_call",
      "should_exist": true,
      "expectation": "DataProvider where expression with direct procedure call must create a direct relation"
    },
    {
      "id": "phase2-case-5-dataprovider-webpanel-link",
      "source": "DataProvider:dpFixoSidebarItems",
      "target": "WebPanel:WWEmbarqueSaida",
      "expected_rule": "webpanel_dot_link",
      "should_exist": true,
      "expectation": "DataProvider effective Source WebPanel .Link() must create a direct relation"
    },
    {
      "id": "phase2-case-6-dataprovider-webpanel-link-with-params",
      "source": "DataProvider:dpFixoSidebarItems",
      "target": "WebPanel:wpEtiquetaInterna",
      "expected_rule": "webpanel_dot_link",
      "should_exist": true,
      "expectation": "DataProvider effective Source WebPanel .Link(...) with parameters must create a direct relation"
    },
    {
      "id": "phase2-case-7-dataprovider-comment-does-not-create-procedure-relation",
      "source": "DataProvider:dpFixoSidebarItems",
      "target": "Procedure:procRecentLinksLoad",
      "expected_rule": "procedure_direct_call",
      "should_exist": false,
      "expectation": "comment-only procedure reference in DataProvider must not create a direct relation"
    },
    {
      "id": "phase2-case-8-dataprovider-comment-does-not-create-webpanel-relation",
      "source": "DataProvider:dpFixoSidebarItems",
      "target": "WebPanel:NucleoMenu",
      "expected_rule": "webpanel_dot_link",
      "should_exist": false,
      "expectation": "comment-only WebPanel .Link() in DataProvider must not create a direct relation"
    },
    {
      "id": "phase2-case-9-procedure-dataprovider-direct-call",
      "source": "Procedure:procMenuItens",
      "target": "DataProvider:dpFixoSidebarItems",
      "expected_rule": "dataprovider_direct_call",
      "should_exist": true,
      "expectation": "Procedure direct DataProvider call must create a direct relation"
    },
    {
      "id": "phase2-case-10-procedure-dataprovider-direct-call-second",
      "source": "Procedure:procMenuItens",
      "target": "DataProvider:dpRecentLinksSidebarItems",
      "expected_rule": "dataprovider_direct_call",
      "should_exist": true,
      "expectation": "Second direct DataProvider call from the same Procedure must create a direct relation"
    },
    {
      "id": "phase2-case-11-webpanel-dataprovider-direct-call",
      "source": "WebPanel:GAMExampleMasterPage",
      "target": "DataProvider:dpGamMenuSidebarItems",
      "expected_rule": "dataprovider_direct_call",
      "should_exist": true,
      "expectation": "WebPanel direct DataProvider call must create a direct relation"
    },
    {
      "id": "phase2-case-12-webpanel-dataprovider-direct-call-with-params",
      "source": "WebPanel:wcEmbarqueSaidaPedidosPrevistos",
      "target": "DataProvider:dpVolumeMovimentoPedidos",
      "expected_rule": "dataprovider_direct_call",
      "should_exist": true,
      "expectation": "WebPanel direct DataProvider call with parameters must create a direct relation"
    },
    {
      "id": "phase2-case-13-webpanel-dataprovider-comment-does-not-create-relation",
      "source": "WebPanel:wpInicializaUFsBrasil",
      "target": "DataProvider:dpCarregaUFsBrasil",
      "expected_rule": "dataprovider_direct_call",
      "should_exist": false,
      "expectation": "comment-only DataProvider call in WebPanel must not create a direct relation"
    },
    {
      "id": "phase2-case-14-workwith-action-procedure",
      "source": "WorkWithForWeb:WorkWithWebAbateOrdem",
      "target": "Procedure:procLimpaGridState",
      "expected_rule": "workwith_action_gxobject",
      "should_exist": true,
      "expectation": "WorkWithForWeb action gxobject pointing to Procedure must create a direct relation"
    },
    {
      "id": "phase2-case-15-workwith-action-webpanel",
      "source": "WorkWithForWeb:WorkWithWebAbateOrdem",
      "target": "WebPanel:wpPesagemAbate",
      "expected_rule": "workwith_action_gxobject",
      "should_exist": true,
      "expectation": "WorkWithForWeb action gxobject pointing to WebPanel must create a direct relation"
    },
    {
      "id": "phase2-case-16-workwith-action-ww-webpanel",
      "source": "WorkWithForWeb:WorkWithWebAbateOrdem",
      "target": "WebPanel:WWEmbarqueSaida",
      "expected_rule": "workwith_action_gxobject",
      "should_exist": true,
      "expectation": "WorkWithForWeb action gxobject pointing to WW WebPanel must create a direct relation"
    },
    {
      "id": "phase2-case-17-workwith-action-unknown-does-not-create-relation",
      "source": "WorkWithForWeb:WorkWithWebAbateOrdem",
      "target": "Procedure:ObjetoInexistenteParaNaoIndexar",
      "expected_rule": "workwith_action_gxobject",
      "should_exist": false,
      "expectation": "WorkWithForWeb action must not create a direct relation for an unresolved target"
    },
    {
      "id": "phase2-case-18-transaction-attcustomtype-sdt-context",
      "source": "Transaction:AbateOrdem",
      "target": "CustomType:sdt:Context",
      "expected_rule": "attcustomtype_property",
      "should_exist": true,
      "expectation": "Transaction ATTCUSTOMTYPE property must create a literal CustomType relation"
    },
    {
      "id": "phase2-case-19-transaction-attcustomtype-bas-boolean",
      "source": "Transaction:AbateOrdem",
      "target": "CustomType:bas:Boolean",
      "expected_rule": "attcustomtype_property",
      "should_exist": true,
      "expectation": "Transaction ATTCUSTOMTYPE built-in type must create a literal CustomType relation"
    },
    {
      "id": "phase2-case-20-procedure-attcustomtype-sdt-context",
      "source": "Procedure:ExportWWOperacaoAjustada",
      "target": "CustomType:sdt:Context",
      "expected_rule": "attcustomtype_property",
      "should_exist": true,
      "expectation": "Procedure ATTCUSTOMTYPE property must create a literal CustomType relation"
    },
    {
      "id": "phase2-case-21-attcustomtype-unknown-does-not-create-relation",
      "source": "Transaction:AbateOrdem",
      "target": "CustomType:sdt:TipoInexistenteParaNaoIndexar",
      "expected_rule": "attcustomtype_property",
      "should_exist": false,
      "expectation": "Absent ATTCUSTOMTYPE value must not create a relation"
    }
  ]
}
